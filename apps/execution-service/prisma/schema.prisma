generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}


model OrderEvent {
  id        String   @id @default(uuid())
  userId    String
  orderId   String   @unique
  quantity  Float
  status    String
  price     String
  createdAt DateTime @default(now())
  timeStamp DateTime
}
