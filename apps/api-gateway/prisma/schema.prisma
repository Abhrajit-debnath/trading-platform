generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String   @id @default(uuid())
  email            String   @unique
  binanceApiKey    String
  binanceSecretKey String
  password         String
  createdAt        DateTime @default(now())
}
