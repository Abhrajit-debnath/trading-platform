generator client {
    provider = "prisma-client-js"
    output   = "../generated"
}

datasource db {
    provider = "postgresql"
}

model User {
    id               String         @id @default(uuid())
    email            String         @unique
    binanceApiKey    String
    binanceSecretKey String
    password         String
    order            OrderCommand[]
    createdAt        DateTime       @default(now())
}

model OrderCommand {
    id            String   @id @default(uuid())
    userId        String
    user          User     @relation(fields: [userId], references: [id])
    orderId       String   @unique
    symbol        String
    side          String
    type          String
    quantity      Float
    status        String   @default("PENDING")
    createdAt     DateTime @default(now())
}

model OrderEvent {
    id        String   @id @default(uuid())
    userId    String
    orderId   String   @unique
    quantity  Float
    status    String
    price     String
    createdAt DateTime @default(now())
    timeStamp DateTime
}
