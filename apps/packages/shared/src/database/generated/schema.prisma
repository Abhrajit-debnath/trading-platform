generator client {
  provider = "prisma-client-js"
  output   = "../generated"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String         @id @default(uuid())
  email            String         @unique
  binanceApiKey    String
  binanceSecretKey String
  password         String
  order            OrderCommand[]
  createdAt        DateTime       @default(now())
}

model OrderCommand {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderId   String   @unique
  symbol    String
  side      String
  price     Float?
  stopPrice Float?
  type      String
  quantity  Float
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
}

model OrderEvent {
  id        String   @id @default(uuid())
  userId    String
  orderId   String   @unique
  quantity  Float
  status    String
  isOpen    Boolean  @default(true)
  side      String   @default("BUY")
  price     Float
  symbol    String
  createdAt DateTime @default(now())
  timeStamp DateTime
}
